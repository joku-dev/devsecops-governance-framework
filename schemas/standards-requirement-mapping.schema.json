{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Standards To Harmonized Requirements Candidate Mapping",
  "type": "object",
  "required": ["schema_version", "mapping_id", "status", "normative", "source_document_id", "source_workbook_digest", "public_source_text_included", "summary", "standards", "mappings"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "mapping_id": { "const": "CISO-STANDARDS-TO-HARMONIZED-REQUIREMENTS" },
    "status": { "const": "candidate" },
    "normative": { "const": false },
    "source_document_id": { "const": "CISO-REQ-SRC-001" },
    "source_workbook_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "public_source_text_included": { "const": false },
    "summary": {
      "type": "object",
      "required": ["raw_rows", "unique_source_requirements", "duplicate_identifier_pairs", "missing_source_ids", "mapped_source_requirements", "unmapped_source_requirements"],
      "properties": {
        "raw_rows": { "type": "integer", "minimum": 1 },
        "unique_source_requirements": { "type": "integer", "minimum": 1 },
        "duplicate_identifier_pairs": { "type": "integer", "minimum": 0 },
        "missing_source_ids": { "type": "integer", "minimum": 0 },
        "mapped_source_requirements": { "type": "integer", "minimum": 1 },
        "unmapped_source_requirements": { "const": 0 }
      },
      "additionalProperties": false
    },
    "standards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["standard_id", "source_label", "raw_rows"],
        "properties": {
          "standard_id": { "type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]*$" },
          "source_label": { "type": "string", "minLength": 1 },
          "raw_rows": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "source_refs", "occurrence_count", "source_strengths", "harmonized_requirement_ids", "mapping_basis", "confidence", "review_status"],
        "properties": {
          "id": { "type": "string", "pattern": "^SRCREQ-[A-F0-9]{12}$" },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["standard_id", "requirement_id"],
              "properties": {
                "standard_id": { "type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]*$" },
                "requirement_id": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "occurrence_count": { "type": "integer", "minimum": 1 },
          "source_strengths": { "type": "array", "minItems": 1, "items": { "enum": ["must", "should", "may", "unclassified"] }, "uniqueItems": true },
          "harmonized_requirement_ids": { "type": "array", "minItems": 1, "maxItems": 5, "items": { "type": "string", "pattern": "^HREQ-[A-Z]+-[0-9]{3}$" }, "uniqueItems": true },
          "mapping_basis": { "enum": ["source_identifier", "content_classification", "fallback_classification"] },
          "confidence": { "enum": ["high", "medium", "low"] },
          "review_status": { "const": "human_review_required" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
