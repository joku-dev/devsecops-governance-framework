{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Report-only Evidence Trust Root Registry",
  "type": "object",
  "required": ["schema_version", "registry_id", "status", "enforcement", "roots"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "registry_id": { "const": "evidence-trust-roots-pilot" },
    "status": { "const": "pilot_report_only" },
    "enforcement": { "const": "report_only" },
    "roots": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key_id", "issuer", "algorithm", "status", "valid_from", "public_key_pem", "permitted_repositories"],
        "properties": {
          "key_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$" },
          "issuer": { "type": "string", "minLength": 1 },
          "algorithm": { "const": "ed25519" },
          "status": { "const": "pilot" },
          "valid_from": { "type": "string", "format": "date-time" },
          "public_key_pem": { "type": "string", "pattern": "^-----BEGIN PUBLIC KEY-----" },
          "permitted_repositories": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[^/]+/[^/]+$" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
