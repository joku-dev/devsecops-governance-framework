{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Document Register",
  "type": "object",
  "required": ["schema_version", "documents"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "source_path",
          "governance_domains",
          "owner",
          "version",
          "intake_date",
          "derived_artifact_areas"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z0-9]+(-[A-Z0-9]+)*-[0-9]{3}$"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["candidate", "draft", "intake", "review", "approved", "superseded", "retired"]
          },
          "source_path": {
            "type": "string"
          },
          "governance_domains": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["policy", "directive", "devsecops", "platform", "architecture"]
            }
          },
          "owner": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "intake_date": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "supersedes": {
            "type": ["string", "null"]
          },
          "superseded_by": {
            "type": ["string", "null"]
          },
          "candidate_replacement_for": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "similarity_assessment": {
            "type": "object",
            "properties": {
              "assessment": {
                "type": "string",
                "enum": [
                  "not_assessed",
                  "new_source",
                  "related_source",
                  "possible_duplicate",
                  "replacement_candidate",
                  "supersedes_existing",
                  "not_relevant"
                ]
              },
              "compared_to": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["source_id", "similarity"],
                  "properties": {
                    "source_id": {
                      "type": "string"
                    },
                    "similarity": {
                      "type": "string",
                      "enum": ["unknown", "low", "medium", "high", "near_duplicate"]
                    },
                    "notes": {
                      "type": "string"
                    }
                  }
                }
              },
              "notes": {
                "type": "string"
              }
            }
          },
          "derived_artifact_areas": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
