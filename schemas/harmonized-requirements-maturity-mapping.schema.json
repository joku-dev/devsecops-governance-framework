{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Harmonized Requirements Candidate Maturity Assignment",
  "type": "object",
  "required": ["schema_version", "mapping_id", "title", "status", "normative", "enforcement", "source_document_id", "requirements_model_id", "cumulative_levels", "derivation_policy", "level_definitions", "decision_required", "mappings", "decision_boundary"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "mapping_id": { "const": "CISO-HARMONIZED-REQUIREMENTS-TO-MATURITY-LEVELS" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "const": "candidate" },
    "normative": { "const": false },
    "enforcement": { "const": "none" },
    "source_document_id": { "const": "CISO-REQ-SRC-001" },
    "requirements_model_id": { "const": "CISO-HARMONIZED-DEVSECOPS-REQUIREMENTS" },
    "cumulative_levels": { "const": true },
    "derivation_policy": { "const": "review_only" },
    "level_definitions": {
      "type": "object",
      "required": ["L1", "L2", "L3", "GOV"],
      "properties": {
        "L1": { "$ref": "#/$defs/levelDefinition" },
        "L2": { "$ref": "#/$defs/levelDefinition" },
        "L3": { "$ref": "#/$defs/levelDefinition" },
        "GOV": { "$ref": "#/$defs/levelDefinition" }
      },
      "additionalProperties": false
    },
    "decision_required": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "mappings": {
      "type": "array",
      "minItems": 44,
      "items": {
        "type": "object",
        "required": ["requirement_id", "minimum_level", "maturity_path", "governance_overlay", "routing_lane", "assignment_basis", "rationale", "review_status"],
        "properties": {
          "requirement_id": { "type": "string", "pattern": "^HREQ-[A-Z]+-[0-9]{3}$" },
          "minimum_level": { "enum": ["L1", "L2", "L3", "GOV"] },
          "maturity_path": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["L1", "L2", "L3", "GOV"] } },
          "governance_overlay": { "type": "boolean" },
          "routing_lane": { "enum": ["governance", "devsecops_baseline", "architecture", "product_security", "platform", "evidence", "operations"] },
          "assignment_basis": { "enum": ["existing_control_alignment", "risk_and_capability", "governance_scope"] },
          "rationale": { "type": "string", "minLength": 20 },
          "review_status": { "const": "human_review_required" }
        },
        "additionalProperties": false
      }
    },
    "decision_boundary": {
      "type": "object",
      "required": ["control_changes_authorized", "policy_changes_authorized", "evidence_contract_changes_authorized", "release_changes_authorized", "enforcement_changes_authorized", "consumer_compliance_claim_authorized"],
      "properties": {
        "control_changes_authorized": { "const": false },
        "policy_changes_authorized": { "const": false },
        "evidence_contract_changes_authorized": { "const": false },
        "release_changes_authorized": { "const": false },
        "enforcement_changes_authorized": { "const": false },
        "consumer_compliance_claim_authorized": { "const": false }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "levelDefinition": {
      "type": "object",
      "required": ["name", "intent"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "intent": { "type": "string", "minLength": 20 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
