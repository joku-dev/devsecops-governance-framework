{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Agent Provenance Index",
  "type": "object",
  "required": ["schema_version", "generated_at", "summary", "records"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "summary": {
      "type": "object",
      "required": ["record_count", "agent_counts", "involvement_counts"],
      "properties": {
        "record_count": { "type": "integer", "minimum": 0 },
        "agent_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "involvement_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
      },
      "additionalProperties": false
    },
    "records": { "type": "array", "items": { "$ref": "evidence-agent-provenance.schema.json" } }
  },
  "additionalProperties": false
}
