{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Collection Attempt",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "attempt_id",
    "enforcement",
    "status",
    "repository_id",
    "evidence_type",
    "collector",
    "attempted_at",
    "source",
    "errors"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "evidence-collection-attempt" },
    "attempt_id": { "type": "string", "minLength": 1 },
    "enforcement": { "const": "report_only" },
    "status": { "enum": ["partial", "failed"] },
    "repository_id": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
    "evidence_type": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "collector": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      },
      "additionalProperties": false
    },
    "attempted_at": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "required": ["provider", "run_id", "artifact_name"],
      "properties": {
        "provider": { "const": "github_actions" },
        "run_id": { "type": "string", "minLength": 1 },
        "run_attempt": { "type": ["integer", "null"], "minimum": 1 },
        "workflow_name": { "type": "string", "minLength": 1 },
        "commit_id": { "type": "string", "minLength": 1 },
        "artifact_name": { "type": "string", "minLength": 1 },
        "source_uri": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "errors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["code", "message", "retryable"],
        "properties": {
          "code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "message": { "type": "string", "minLength": 1 },
          "retryable": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
