{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Trust Model",
  "type": "object",
  "required": [
    "schema_version",
    "model_id",
    "title",
    "status",
    "source_document",
    "owner",
    "adoption",
    "principles",
    "trust_dimensions",
    "verification_checks",
    "trust_levels",
    "decision_rules",
    "migration_gaps",
    "migration_phases",
    "open_decisions"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "model_id": { "const": "evidence-trust-model-v1" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "active_report_only", "released"] },
    "source_document": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "adoption": {
      "type": "object",
      "required": [
        "contract_impact",
        "enforcement",
        "existing_evidence_default",
        "trust_does_not_imply_governance_pass",
        "governance_pass_does_not_imply_trust",
        "existing_snapshots_reclassified"
      ],
      "properties": {
        "contract_impact": { "enum": ["none", "additive", "breaking"] },
        "enforcement": { "enum": ["report_only", "blocking"] },
        "existing_evidence_default": { "type": "string" },
        "trust_does_not_imply_governance_pass": { "type": "boolean" },
        "governance_pass_does_not_imply_trust": { "type": "boolean" },
        "existing_snapshots_reclassified": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "principles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/idStatement" }
    },
    "trust_dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "required_claims"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "description": { "type": "string", "minLength": 10 },
          "required_claims": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "verification_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "dimension", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "dimension": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "description": { "type": "string", "minLength": 10 }
        },
        "additionalProperties": false
      }
    },
    "trust_levels": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "id",
          "rank",
          "description",
          "required_dimensions",
          "required_checks",
          "recommended_uses",
          "not_sufficient_for"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "rank": { "type": "integer", "minimum": 0 },
          "description": { "type": "string", "minLength": 10 },
          "required_dimensions": { "$ref": "#/$defs/uniqueStringArray" },
          "required_checks": { "$ref": "#/$defs/uniqueStringArray" },
          "recommended_uses": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
          "not_sufficient_for": { "$ref": "#/$defs/nonEmptyUniqueStringArray" }
        },
        "additionalProperties": false
      }
    },
    "decision_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "requirement"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "requirement": { "type": "string", "minLength": 10 }
        },
        "additionalProperties": false
      }
    },
    "migration_gaps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "scope", "current_state", "missing_capabilities", "target_level", "priority", "phase"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "scope": { "enum": ["shared", "devsecops_intake", "architecture_intake"] },
          "current_state": { "type": "string", "minLength": 10 },
          "missing_capabilities": { "$ref": "#/$defs/nonEmptyStringArray" },
          "target_level": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "priority": { "enum": ["high", "medium", "low"] },
          "phase": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
        },
        "additionalProperties": false
      }
    },
    "migration_phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "order", "state", "objective", "enforcement"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "order": { "type": "integer", "minimum": 1 },
          "state": { "enum": ["current", "planned", "gated", "complete"] },
          "objective": { "type": "string", "minLength": 10 },
          "enforcement": { "enum": ["report_only", "decision_required", "blocking"] }
        },
        "additionalProperties": false
      }
    },
    "open_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "question", "required_reviewers", "blocking_for_phase"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "question": { "type": "string", "minLength": 10 },
          "required_reviewers": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
          "blocking_for_phase": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "idStatement": {
      "type": "object",
      "required": ["id", "statement"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "statement": { "type": "string", "minLength": 10 }
      },
      "additionalProperties": false
    },
    "uniqueStringArray": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
      "uniqueItems": true
    },
    "nonEmptyUniqueStringArray": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
      "uniqueItems": true
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
