{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Collector Record",
  "type": "object",
  "required": [
    "contract_id",
    "contract_version",
    "status",
    "enforcement",
    "evidence_type",
    "governance_domain",
    "collector",
    "produced_at",
    "captured_at",
    "source",
    "subjects",
    "custody",
    "errors"
  ],
  "properties": {
    "contract_id": { "const": "evidence-collector-contract" },
    "contract_version": { "const": "0.1.0" },
    "status": { "enum": ["collected", "partial", "failed"] },
    "enforcement": { "const": "report_only" },
    "evidence_type": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "governance_domain": { "enum": ["devsecops", "architecture"] },
    "collector": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      },
      "additionalProperties": false
    },
    "produced_at": { "type": "string", "format": "date-time" },
    "captured_at": { "type": "string", "format": "date-time" },
    "source": { "$ref": "#/$defs/source" },
    "subjects": {
      "type": "array",
      "items": { "$ref": "#/$defs/subject" }
    },
    "custody": {
      "type": "array",
      "items": { "$ref": "#/$defs/custodyStep" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/collectionError" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "collected" } }, "required": ["status"] },
      "then": {
        "properties": {
          "subjects": { "minItems": 1 },
          "custody": { "minItems": 2 },
          "errors": { "maxItems": 0 }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "partial" } }, "required": ["status"] },
      "then": {
        "properties": {
          "subjects": { "minItems": 1 },
          "custody": { "minItems": 1 },
          "errors": { "minItems": 1 }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "failed" } }, "required": ["status"] },
      "then": {
        "properties": {
          "subjects": { "maxItems": 0 },
          "custody": { "minItems": 1 },
          "errors": { "minItems": 1 }
        }
      }
    },
    {
      "if": { "properties": { "evidence_type": { "const": "governance_result" } }, "required": ["evidence_type"] },
      "then": {
        "properties": {
          "source": {
            "required": [
              "provider",
              "repository_id",
              "commit_id",
              "workflow_name",
              "run_id",
              "run_attempt",
              "artifact_name",
              "source_uri"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "source": {
      "type": "object",
      "required": ["provider", "source_uri"],
      "properties": {
        "provider": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "repository_id": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "commit_id": { "type": "string", "minLength": 1 },
        "workflow_name": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "minLength": 1 },
        "run_attempt": { "type": "integer", "minimum": 1 },
        "artifact_name": { "type": "string", "minLength": 1 },
        "source_uri": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "subject": {
      "type": "object",
      "required": ["id", "evidence_ref", "algorithm", "digest", "size_bytes"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "evidence_ref": { "type": "string", "minLength": 1 },
        "algorithm": { "const": "sha256" },
        "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "size_bytes": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "custodyStep": {
      "type": "object",
      "required": ["sequence", "action", "actor", "at", "source_uri", "output_refs"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 1 },
        "action": { "enum": ["download", "extract_and_hash"] },
        "actor": { "type": "string", "minLength": 1 },
        "at": { "type": "string", "format": "date-time" },
        "source_uri": { "type": "string", "minLength": 1 },
        "output_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "collectionError": {
      "type": "object",
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "message": { "type": "string", "minLength": 1 },
        "retryable": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
