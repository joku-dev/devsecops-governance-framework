{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Application Architecture Evidence",
  "type": "object",
  "required": ["evidence_type", "status", "owner", "evidence_refs"],
  "properties": {
    "evidence_type": {
      "type": "string",
      "enum": [
        "architecture_document",
        "context_view",
        "building_block_view",
        "architecture_decision_record",
        "architecture_ownership_record",
        "model_based_architecture",
        "sysml_model",
        "uml_model",
        "model_export",
        "model_baseline_record",
        "model_review_record",
        "interface_catalogue",
        "interface_contract",
        "data_contract",
        "contract_test_result",
        "compatibility_matrix",
        "solution_baseline",
        "product_baseline",
        "release_compatibility_declaration",
        "baseline_delta_assessment",
        "migration_impact_assessment",
        "security_architecture_review",
        "threat_model",
        "trust_zone_model",
        "identity_and_access_model",
        "crypto_assumption_record",
        "security_test_evidence",
        "security_evidence",
        "deployment_document",
        "deployment_manifest",
        "runtime_configuration_evidence",
        "observability_evidence",
        "operations_runbook",
        "rollback_evidence",
        "resilience_scenario",
        "resilience_test_evidence",
        "backup_restore_evidence",
        "failure_mode_evidence",
        "operational_recovery_record",
        "resilience_evidence",
        "operation_evidence",
        "architecture_review_record",
        "approval_record",
        "design_authority_decision",
        "quality_gate_result",
        "owner_assignment",
        "review_evidence",
        "architecture_exception",
        "risk_acceptance_record",
        "mitigation_plan",
        "expiry_review_record",
        "exception_evidence",
        "operational_finding",
        "demo_or_review_finding",
        "technical_debt_item",
        "improvement_backlog_item",
        "closed_improvement_action",
        "feedback_evidence"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewed", "approved"]
    },
    "owner": { "type": "string" },
    "baseline_version": { "type": "string" },
    "tool": { "type": "string" },
    "tool_version": { "type": "string" },
    "model_file": { "type": "string" },
    "model_export": { "type": "string" },
    "baseline_id": { "type": "string" },
    "model_version": { "type": "string" },
    "hash": { "type": "string" },
    "approved_by": { "type": "string" },
    "approval_date": { "type": "string" },
    "summary": { "type": "string" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "known_limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "follow_up_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
