{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance Repository Self-Security Profile",
  "type": "object",
  "required": ["schema_version", "profile_id", "version", "title", "status", "repository_id", "source_documents", "owner", "enforcement", "enforcement_change_authorized", "purpose", "principles", "criteria", "decision_boundary"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "profile_id": { "const": "governance-repository-self-security" },
    "version": { "type": "string", "pattern": "^0\\.[0-9]+\\.[0-9]+$" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "const": "active_report_only" },
    "repository_id": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
    "source_documents": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "owner": { "type": "string", "minLength": 1 },
    "enforcement": { "const": "report_only" },
    "enforcement_change_authorized": { "const": false },
    "purpose": { "type": "string", "minLength": 1 },
    "principles": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "statement"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "statement": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "criteria": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "required": ["id", "key", "title", "severity", "expected"],
        "properties": {
          "id": { "type": "string", "pattern": "^GRS-[0-9]{3}$" },
          "key": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "title": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["critical", "high", "medium", "low"] },
          "expected": { "const": true }
        },
        "additionalProperties": false
      }
    },
    "decision_boundary": {
      "type": "object",
      "required": ["current_mode", "blocks_pull_requests", "changes_repository_settings", "changes_released_baselines", "blocking_requires"],
      "properties": {
        "current_mode": { "const": "report_only" },
        "blocks_pull_requests": { "const": false },
        "changes_repository_settings": { "const": false },
        "changes_released_baselines": { "const": false },
        "blocking_requires": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
