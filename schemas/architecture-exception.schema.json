{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Architecture Exception",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "target",
    "affected_scope",
    "business_reason",
    "architecture_impact",
    "risk",
    "owner",
    "mitigation",
    "risk_classification",
    "review_date",
    "expiry_date",
    "approval_authority"
  ],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["proposed", "approved", "rejected", "conditionally_approved", "expired", "closed"]
    },
    "target": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["guardrail", "quality_marker", "solution_baseline", "interface_rule", "data_rule", "security_rule", "runtime_rule", "deployment_assumption"]
        },
        "id": { "type": "string" }
      }
    },
    "affected_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "business_reason": { "type": "string" },
    "architecture_impact": { "type": "string" },
    "bapo_implications": {
      "type": "object",
      "properties": {
        "business": { "type": "string" },
        "architecture": { "type": "string" },
        "process": { "type": "string" },
        "organization": { "type": "string" }
      }
    },
    "risk": { "type": "string" },
    "alternatives_considered": {
      "type": "array",
      "items": { "type": "string" }
    },
    "owner": { "type": "string" },
    "mitigation": { "type": "string" },
    "risk_classification": { "type": "string" },
    "review_date": { "type": "string" },
    "expiry_date": { "type": "string" },
    "approval_authority": { "type": "string" },
    "conditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "follow_up_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
